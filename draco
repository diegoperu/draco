set -euo pipefail
IFS=$'\n\t'

# ─── Version ──────────────────────────────────────────────────────────────────
readonly DRACO_VERSION="1.0.0"
readonly DRACO_NAME="DRACO"

# ─── Paths ────────────────────────────────────────────────────────────────────
readonly DRACO_SELF="$(realpath "${BASH_SOURCE[0]}")"
readonly DRACO_DIR="$(dirname "$DRACO_SELF")"
readonly DRACO_SRC="${DRACO_DIR}/src"

# ─── Source core modules ──────────────────────────────────────────────────────
# shellcheck source=src/core/config.sh
source "${DRACO_SRC}/core/config.sh"
# shellcheck source=src/core/log.sh
source "${DRACO_SRC}/core/log.sh"
# shellcheck source=src/core/utils.sh
source "${DRACO_SRC}/core/utils.sh"
# shellcheck source=src/distro/detect.sh
source "${DRACO_SRC}/distro/detect.sh"
# shellcheck source=src/backup/engine.sh
source "${DRACO_SRC}/backup/engine.sh"
# shellcheck source=src/restore/engine.sh
source "${DRACO_SRC}/restore/engine.sh"
# shellcheck source=src/scheduler/scheduler.sh
source "${DRACO_SRC}/scheduler/scheduler.sh"
# shellcheck source=src/tui/tui.sh
source "${DRACO_SRC}/tui/tui.sh"

# ─── Usage ────────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
${DRACO_NAME} v${DRACO_VERSION} - Dotfile & Runtime Archive and Configuration Orchestrator

USAGE:
    draco [OPTIONS] COMMAND

COMMANDS:
    backup              Run backup now
    restore [ID]        Restore a backup (interactive if no ID given)
    list                List all backups with sizes and dates
    log [ID]            Show backup log (diff vs previous if ID given)
    delete [ID]         Delete one or more backups (interactive if no ID)
    config              Configure DRACO settings
    schedule            Manage automatic scheduling
    status              Show current config and last backup info

OPTIONS:
    -c, --config FILE   Use alternate config file
    -p, --password PWD  Encryption password (or set DRACO_PASSWORD env var)
    -q, --quiet         Suppress non-error output
    -v, --verbose       Verbose output
    --no-color          Disable color output
    --tui               Force TUI mode (default if no command given)
    --version           Show version
    -h, --help          Show this help

EXAMPLES:
    draco                           # Launch TUI
    draco backup                    # Run backup now
    draco restore                   # Interactive restore
    draco restore 20260508-143022   # Restore specific backup
    draco list                      # List backups
    draco log 20260508-143022       # Show diff for backup
    draco delete 20260101-120000    # Delete backup
    draco schedule install          # Install automatic schedule
    draco config                    # Configure settings

ENVIRONMENT:
    DRACO_PASSWORD      Encryption password (avoids prompt)
    DRACO_CONFIG        Path to config file
    DRACO_BACKUP_DIR    Override backup directory

See draco(1) for full documentation.
EOF
}

# ─── Argument parsing ─────────────────────────────────────────────────────────
parse_args() {
    DRACO_CMD=""
    DRACO_CMD_ARG=""
    DRACO_FORCE_TUI=0
    DRACO_QUIET=0
    DRACO_VERBOSE=0
    DRACO_NO_COLOR=0
    DRACO_ALT_CONFIG=""
    DRACO_CLI_PASSWORD=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            backup|restore|list|log|delete|config|schedule|status)
                DRACO_CMD="$1"
                if [[ $# -gt 1 && ! "$2" =~ ^- ]]; then
                    DRACO_CMD_ARG="$2"
                    shift
                fi
                ;;
            -c|--config)
                DRACO_ALT_CONFIG="${2:?'--config requires a file path'}"
                shift
                ;;
            -p|--password)
                DRACO_CLI_PASSWORD="${2:?'--password requires a value'}"
                shift
                ;;
            -q|--quiet)    DRACO_QUIET=1 ;;
            -v|--verbose)  DRACO_VERBOSE=1 ;;
            --no-color)    DRACO_NO_COLOR=1 ;;
            --tui)         DRACO_FORCE_TUI=1 ;;
            --version)     echo "${DRACO_NAME} v${DRACO_VERSION}"; exit 0 ;;
            -h|--help)     usage; exit 0 ;;
            *)
                draco_error "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
        shift
    done
}

# ─── First run check ──────────────────────────────────────────────────────────
first_run_check() {
    if [[ ! -f "$DRACO_CONFIG_FILE" ]]; then
        draco_info "First run detected. Running initial setup..."
        draco_first_run_setup
    fi
}

# ─── Main dispatcher ──────────────────────────────────────────────────────────
main() {
    parse_args "$@"

    # Load config (uses alt config if set)
    draco_load_config "${DRACO_ALT_CONFIG:-}"

    # Apply CLI overrides
    [[ -n "$DRACO_CLI_PASSWORD" ]] && DRACO_PASSWORD="$DRACO_CLI_PASSWORD"
    [[ -n "${DRACO_PASSWORD:-}" ]] || DRACO_PASSWORD="${DRACO_PASSWORD:-}"

    # Init logging
    draco_log_init

    # No command = TUI
    if [[ -z "$DRACO_CMD" ]] || [[ "$DRACO_FORCE_TUI" -eq 1 ]]; then
        draco_tui_main
        exit 0
    fi

    # First run check (only for backup/restore/schedule)
    if [[ "$DRACO_CMD" =~ ^(backup|restore|schedule)$ ]]; then
        first_run_check
    fi

    # Dispatch
    case "$DRACO_CMD" in
        backup)   draco_backup_run ;;
        restore)  draco_restore_run "${DRACO_CMD_ARG:-}" ;;
        list)     draco_backup_list ;;
        log)      draco_backup_show_log "${DRACO_CMD_ARG:-}" ;;
        delete)   draco_backup_delete "${DRACO_CMD_ARG:-}" ;;
        config)   draco_config_wizard ;;
        schedule) draco_schedule_cmd "${DRACO_CMD_ARG:-}" ;;
        status)   draco_status ;;
    esac
}

main "$@"
